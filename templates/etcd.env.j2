# Managed by Ansible — do not edit manually
ETCD_NAME="{{ inventory_hostname }}"
ETCD_DATA_DIR="{{ etcd_data_dir }}"
ETCD_LISTEN_CLIENT_URLS="http://0.0.0.0:{{ etcd_client_port }}"
ETCD_ADVERTISE_CLIENT_URLS="http://{{ _etcd_advertise_address }}:{{ etcd_client_port }}"
ETCD_LISTEN_PEER_URLS="http://0.0.0.0:{{ etcd_peer_port }}"
ETCD_INITIAL_ADVERTISE_PEER_URLS="http://{{ _etcd_advertise_address }}:{{ etcd_peer_port }}"
ETCD_INITIAL_CLUSTER="{{ inventory_hostname }}=http://{{ _etcd_advertise_address }}:{{ etcd_peer_port }}"
ETCD_INITIAL_CLUSTER_TOKEN="etcd-cluster-{{ patroni_scope }}"
ETCD_INITIAL_CLUSTER_STATE="{{ etcd_initial_cluster_state }}"
